{
  "name": "vscode-extension-project",
  "displayName": "vscode-extension-project",
  "description": "vscode vue组件自动收集和提示工具",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hsxzn/vscode-extension-project.git"
  },
  "license": "MIT",
  "version": "0.0.7",
  "publisher": "Hsxzn",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.60.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:extension.generatePropsHints",
    "onCommand:extension.openPropsHintsSettings",
    "onCommand:extension.openPropsHintsFile",
    "onCommand:extension.openCurrentFileInInternalBrowser",
    "onCommand:extension.openCurrentFileInSystemBrowser"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.generatePropsHints",
        "title": "collect props:Generate Vue/JS Props Hints"
      },
      {
        "command": "extension.openPropsHintsSettings",
        "title": "collect props:Open Props Hints Settings"
      },
      {
        "command": "extension.openPropsHintsFile",
        "title": "collect props:Open Generated Props Hints File"
      },
      {
        "command": "extension.openCurrentFileInInternalBrowser",
        "title": "VS Code 中打开",
        "category": "打开文件"
      },
      {
        "command": "extension.openCurrentFileInSystemBrowser",
        "title": "系统浏览器打开",
        "category": "打开文件"
      }
    ],
    "submenus": [
      {
        "id": "extension.openFileSubmenu",
        "label": "打开文件"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "extension.openFileSubmenu",
          "when": "explorerResourceIsFolder == false && resourceScheme == file",
          "group": "9_openFile@1"
        }
      ],
      "editor/context": [
        {
          "submenu": "extension.openFileSubmenu",
          "when": "resourceScheme == file",
          "group": "9_openFile@1"
        }
      ],
      "extension.openFileSubmenu": [
        {
          "command": "extension.openCurrentFileInInternalBrowser",
          "group": "1_browser@1"
        },
        {
          "command": "extension.openCurrentFileInSystemBrowser",
          "group": "1_browser@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "build:ts": "tsc -p .",
    "build:bundle": "webpack --mode production",
    "compile": "npm run build:ts && npm run build:bundle",
    "package:vsix": "vsce package"
  },
  "devDependencies": {
    "@types/chai": "^4.2.21",
    "@types/mocha": "^9.0.0",
    "@types/node": "^16.9.1",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "chai": "^4.3.4",
    "eslint": "^7.32.0",
    "glob": "^13.0.0",
    "mocha": "^9.1.3",
    "ts-loader": "^9.2.6",
    "typescript": "^4.4.3",
    "webpack": "^5.51.1",
    "webpack-cli": "^4.8.0"
  }
}
